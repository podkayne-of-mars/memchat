server:
  host: "0.0.0.0"
  port: 8080

anthropic:
  # API key loaded from ANTHROPIC_API_KEY env var — never stored here
  conversation_model: "claude-sonnet-4-20250514"
  curator_model: "claude-haiku-4-5-20251001"
  max_context_tokens: 200000
  handover_threshold: 0.70

conversation:
  buffer_messages: 20
  max_knowledge_entries: 30

curator:
  backend: "anthropic"
  local_model: "mistral"

database:
  path: "./data/immortalchat.db"
